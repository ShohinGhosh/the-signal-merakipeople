# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/the-signal?retryWrites=true&w=majority

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this

# AI - Anthropic Claude (primary generator)
ANTHROPIC_API_KEY=sk-ant-...

# AI - Google Gemini (critique agent / fallback)
GEMINI_API_KEY=your-gemini-api-key

# Google API (for Gemini — can be same as GEMINI_API_KEY)
GOOGLE_API_KEY=your-google-api-key

# Serper (web search for company research)
SERPER_API_KEY=your-serper-api-key

# Perplexity
PERPLEXITY_API_KEY=your-perplexity-api-key

# AI - fal.ai Image Generation
FAL_KEY=your-fal-ai-key

# Meta Business Account (Instagram publishing & analytics)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:3000/settings

# Server
PORT=5000
NODE_ENV=development

# Client (also in client/.env)
VITE_API_URL=http://localhost:5000/api
